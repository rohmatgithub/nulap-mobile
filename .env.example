# API Configuration
EXPO_PUBLIC_API_URL=http://localhost:8686/api/v1

# App ID for authentication (must match backend constanta.AppIDNulap)
EXPO_PUBLIC_APP_ID=nulap-app

# Google Auth
# Must match backend auth.google.clientId unless backend is configured for multiple audiences.
EXPO_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
